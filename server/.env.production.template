# ─── Required ─────────────────────────────────────────────────────────────────

# PostgreSQL password (used by both server and postgres container)
POSTGRES_PASSWORD=

# JWT signing secret (must be 32+ characters in production)
# Generate with: openssl rand -base64 48
JWT_SECRET=

# Stripe keys (get from https://dashboard.stripe.com/apikeys — use LIVE keys)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Optional (receipt delivery) ──────────────────────────────────────────────

# Twilio (for SMS receipts)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Resend (email provider for receipts)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# SendGrid (legacy — kept for env compat)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
